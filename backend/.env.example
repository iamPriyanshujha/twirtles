# Twirtles Backend Environment variables Configuration Blueprint
PORT=5000

# Connection URI for local or Mongo Atlas cloud databases
MONGO_URI=mongodb://localhost:27017/twirtles

# JSON Web Token secret signature used for password sessions
JWT_SECRET=twirtles_super_secure_secret_key_1402

# ----------------------------------------------------
# RAZORPAY INTEGRATION (Payment Gateway)
# ----------------------------------------------------
# Obtain these keys from your Razorpay Dashboard (Settings > API Keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ----------------------------------------------------
# AUTOMATED CUSTOMER EMAIL NOTIFICATIONS (Nodemailer config)
# ----------------------------------------------------
# Example SMTP setup using GMail hosting services
NODEMAILER_USER=
NODEMAILER_PASS=

# ----------------------------------------------------
# TWILIO SMS LOGISTICS (Text Messaging alerts)
# ----------------------------------------------------
# Credentials retrieved from console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

