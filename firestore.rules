rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helper primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'priyanshujha1402@gmail.com' || 
        request.auth.token.email == 'priyanshujha2610@gmail.com'
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint for UserProfile configuration
    function isValidUserProfile(data) {
      return data.uid == request.auth.uid 
        && data.email is string && data.email.size() <= 150
        && data.displayName is string && data.displayName.size() <= 150
        && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 800)
        && (data.get('phone', '') is string && data.get('phone', '').size() <= 60)
        && (data.get('deliveryAddress', '') is string && data.get('deliveryAddress', '').size() <= 400)
        && (data.get('city', '') is string && data.get('city', '').size() <= 150)
        && (data.get('state', '') is string && data.get('state', '').size() <= 150)
        && (data.get('pinCode', '') is string && data.get('pinCode', '').size() <= 30)
        && (data.get('role', '') is string && data.get('role', '').size() <= 30)
        && (data.get('wishlist', []) is list)
        && (data.get('updatedAt', null) == null || data.updatedAt is timestamp);
    }

    // Validation Blueprint for Purchase Orders
    function isValidOrder(data) {
      return data.orderId is string && data.orderId.size() <= 50
        && data.userId == request.auth.uid
        && data.userEmail is string && data.userEmail.size() <= 150
        && data.total is number && data.total >= 0
        && data.paymentMethod is string && (data.paymentMethod == 'cod' || data.paymentMethod == 'razorpay')
        && data.paymentStatus is string && data.paymentStatus.size() <= 50
        && data.orderStatus is string && data.orderStatus.size() <= 50
        && data.recipientName is string && data.recipientName.size() <= 150
        && data.phone is string && data.phone.size() <= 30
        && data.shippingAddress is string && data.shippingAddress.size() <= 500
        && data.city is string && data.city.size() <= 100
        && data.state is string && data.state.size() <= 100
        && data.pinCode is string && data.pinCode.size() <= 15
        && data.items is list && data.items.size() > 0 && data.items.size() <= 50
        && data.get('paymentId', '') is string && data.get('paymentId', '').size() <= 100
        && (data.get('courierCollected', null) == null || data.courierCollected is bool)
        && (data.get('customerAcknowledged', null) == null || data.customerAcknowledged is bool)
        && (data.get('adminConfirmed', null) == null || data.adminConfirmed is bool)
        && data.createdAt == request.time;
    }

    // 1. User Profile Document Path Rule
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId) && isValidUserProfile(incoming());
      allow delete: if false; // Profiles cannot be deleted from customer facing SDK
    }

    // 2. Orders Collection Path Rule
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isSignedIn() && (
                      (resource.data.userId == request.auth.uid && (
                        incoming().diff(existing()).affectedKeys().hasOnly([
                          'paymentStatus', 'paymentId', 'courierCollected', 'customerAcknowledged', 'updatedAt'
                        ])
                      ))
                      || isAdmin()
                    );
      allow delete: if false; // Orders cannot be deleted
    }

    // 3. Products CMS Collection Path Rule
    match /products/{productId} {
      allow read: if true; // Public browse access for everyone to enjoy high-quality snacks
      allow write: if isAdmin(); // Strictly gated to admin only
    }

  }
}
